# ── SERVEUR ──
PORT=3000
NODE_ENV=development

# ── BASE DE DONNÉES (Railway l'injecte automatiquement en production) ──
DATABASE_URL=postgresql://user:password@host:5432/studiokay_db

# ── JWT ──
JWT_SECRET=studiokay_super_secret_change_moi_en_production

# ── EMAIL GMAIL ──
GMAIL_USER=kamsenconciergerie@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── URL DE L'APP ──
APP_URL=https://studiokay-production.up.railway.app

# ── CLOUDINARY (stockage photos) ──
# Copier la valeur CLOUDINARY_URL depuis le dashboard cloudinary.com
# Format : cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://123456789012345:votre_api_secret@votre_cloud_name
